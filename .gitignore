# Dependencies
node_modules/
.pnpm-debug.log*

# Build Outputs
dist/
build/
out/
*.tsbuildinfo

# IDE & OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Testing
coverage/
.nyc_output

# Environment & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# Turbo / Cache
.turbo/
.cache/
.eslintcache

# Project Specific
apps/gateway/dist/
apps/web/dist/
apps/cli/dist/
packages/*/dist/

