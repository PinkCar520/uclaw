{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pinkcar.dev/agp/schema/agp-manifest.schema.json",
  "title": "AGP Manifest Schema",
  "description": "JSON Schema for validating AGP (Agent Governance Protocol) v1.0 manifest files",
  "type": "object",
  "required": ["protocol", "name", "description", "allowed-tools"],
  "properties": {
    "protocol": {
      "type": "string",
      "pattern": "^AGP/\\d+\\.\\d+$",
      "description": "AGP 协议版本声明，格式为 AGP/<版本号>，如 AGP/1.0",
      "examples": ["AGP/1.0"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "工作流唯一名称标识符，建议使用 kebab-case"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "触发时机描述，用于网关意图路由匹配"
    },
    "license": {
      "type": "string",
      "description": "许可证声明"
    },
    "compatibility": {
      "type": "string",
      "description": "运行环境依赖声明"
    },
    "allowed-tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "AGP 核心字段：动态工具沙盒白名单。网关仅向大模型注入此列表中的 MCP 工具，其余工具物理隔离。"
    },
    "requires-approval": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "AGP 拦截断点：列出的工具在调用前必须经过人工 Y/N 确认，网关层程序化强制拦截。"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": {
          "type": "string",
          "description": "作者或团队名称"
        },
        "version": {
          "type": "string",
          "description": "工作流版本号"
        },
        "target-system": {
          "type": "string",
          "description": "适用的目标系统"
        }
      }
    }
  },
  "additionalProperties": true
}
