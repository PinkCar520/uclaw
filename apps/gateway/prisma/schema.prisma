// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 影子用户信息表（SSO 自动同步）
model User {
  id          String   @id @default(uuid())
  workId      String   @unique // 工号，唯一标识
  name        String?
  email       String?
  avatar      String?
  department  String?
  password    String? // Hashed password for local authentication

  // 关联信息
  preferences     UserPreference?
  credentials     UserCredential[]
  sessions        Session[]
  skillInstallations SkillInstallation[]
  apiKeys         ApiKey[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

// 用户 AI 个性化配置
model UserPreference {
  id           String @id @default(uuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  defaultModel String @default("deepseek-v3")
  language     String @default("zh-CN")
  theme        String @default("system")

  // 存储常用 Prompt、工作流偏好等
  config       Json?

  @@map("user_preferences")
}

// API Key 管理（用于 CLI / 第三方应用认证）
model ApiKey {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  key         String   @unique  // uclaw_sk_ 前缀的 API Key
  name        String   // Key 名称/备注，如 "CLI Daemon", "VSCode Extension"
  permissions String[] @default(["read", "write", "execute"]) // 权限范围
  lastUsedAt  DateTime? // 最后使用时间
  expiresAt   DateTime? // 过期时间（NULL = 永不过期）
  revoked     Boolean  @default(false) // 是否已撤销

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([key])
  @@index([revoked])
  @@map("api_keys")
}

// 外部系统凭证（如禅道、GitLab Token）
model UserCredential {
  id         String @id @default(uuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  systemType String // 'zentao', 'gitlab', 'jenkins'
  token      String // 加密后的 Token
  username   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, systemType])
  @@map("user_credentials")
}

// 跨端会话（支持 Web/CLI/IM 漫游）
model Session {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String    @default("New Chat") // 会话标题
  channel   String    @default("web")      // 'web', 'cli', 'im'
  status    String    @default("active")   // 'active' | 'archived'
  messages  Message[]
  tasks     Task[]    // 编排任务列表
  approvalRequests ApprovalRequest[]       // 该会话的审批请求

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("sessions")
}

// 编排任务（Orchestration Task）
model Task {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  subject     String   // 任务标题
  status      String   @default("todo") // 'todo' | 'doing' | 'done' | 'failed'
  order       Int      @default(0)      // 排序
  parentId    String?  // 父任务 ID (用于级联)
  metadata    Json?    // 任务元数据 (如 progress, error, toolCallId)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
  @@map("tasks")
}

// 对话消息（每条消息独立存储，Server as Source of Truth）
model Message {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  parentId    String?  // 父消息 ID，用于支持对话分支（Tree 结构）
  role        String   // 'user' | 'assistant' | 'system'
  content     String   @default("") // 消息文本内容
  parts       Json?    // AI SDK UIMessage parts（含 tool-invocation 等）
  attachments Json?    // 附件列表（url, name, contentType）
  usage       Json?    // Token 用量 { inputTokens, outputTokens, totalTokens }
  
  // Tracing 关联
  traceId     String?  // 关联的可观测性 Trace ID

  capsuleSnapshots CapsuleSnapshot[]

  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([parentId])
  @@index([traceId])
  @@map("messages")
}

// RAG 知识库文档
model Document {
  id          String   @id @default(uuid())
  title       String
  sourceUrl   String?  @map("sourceUrl")
  sourceType  String   @default("file") @map("sourceType")
  status      String   @default("processing") 
  userId      String?  @map("userId")
  
  // 关联项目
  projectId   String?  @map("projectId")
  project     KnowledgeProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  chunks      DocumentChunk[]
  
  metadata    Json?    
  createdAt   DateTime @default(now()) @map("createdAt")
  updatedAt   DateTime @updatedAt @map("updatedAt")

  @@map("documents")
}

// 知识库项目（用于分组管理文档）
model KnowledgeProject {
  id          String     @id @default(uuid())
  name        String     
  category    String     
  description String?    @db.Text
  iconUrl     String?    @map("iconUrl")
  color       String?    
  
  documents   Document[] 
  
  userId      String?    @map("userId")
  isPublic    Boolean    @default(true) @map("isPublic")
  
  createdAt   DateTime   @default(now()) @map("createdAt")
  updatedAt   DateTime   @updatedAt @map("updatedAt")

  @@map("knowledge_projects")
}

// RAG 文档切片
model DocumentChunk {
  id          String   @id @default(uuid())
  documentId  String   @map("documentId")
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  content     String   @db.Text
  index       Int      
  
  embedding   Json?    
  metadata    Json?    
  tsv         Unsupported("tsvector")?

  @@index([documentId])
  @@map("document_chunks")
}

// 链路追踪 (Tracing)
model Trace {
  id          String   @id @default(uuid())
  traceId     String   @unique
  name        String   // Trace 名称 (e.g., "Chat Request")
  userId      String?
  sessionId   String?
  
  spans       Span[]
  
  duration    Int?     // 耗时 (ms)
  status      String   @default("ok") // 'ok', 'error'
  metadata    Json?
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@map("traces")
}

model Span {
  id          String   @id @default(uuid())
  traceId     String
  trace       Trace    @relation(fields: [traceId], references: [traceId], onDelete: Cascade)
  
  spanId      String
  parentSpanId String?
  name        String   // Span 名称 (e.g., "Tool Call: zentao")
  kind        String   @default("internal") // 'client', 'server', 'internal'
  
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  
  attributes  Json?    // 标签与属性
  events      Json?    // 日志事件

  @@index([traceId])
  @@map("spans")
}

// Capsule（交互胶囊）快照表
// 将工具返回的 UI 内容持久化为自包含快照，确保历史对话不依赖外部 API 也能准确还原
// 设计原则：快照存储（非引用），离线可查看，跨设备一致
model CapsuleSnapshot {
  id          String   @id @default(uuid())
  messageId   String
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  toolCallId  String   // 对应 tool invocation 的唯一标识
  uiType      String   // 'bug_card' / 'pipeline_card' / 'approval_card' / ...
  title       String   @default("")  // 快照标题，如 "缺陷 BUG-123"
  content     Json     // 完整 UI props 快照（自包含，不依赖外部 API）
  version     Int      @default(1)   // 同一 toolCall 的迭代版本号（未来支持 v1→v2 切换）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([messageId, toolCallId, version])  // 同一消息下同一工具调用的唯一快照
  @@index([messageId])
  @@map("capsule_snapshots")
}

// 审批请求持久化表
// 替代原有的内存 Map 存储，支持多实例部署、重启不丢失、超时自动过期
model ApprovalRequest {
  id          String   @id @default(uuid()) @db.VarChar(64)
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  toolName    String                        // 需要审批的工具名称
  args        Json                          // 工具调用参数快照
  status      String   @default("pending")  // 'pending' | 'approved' | 'denied'
  responseBy  String?  @db.VarChar(20)     // 操作人工号（谁批准的）
  responseAt  DateTime?                     // 批准/拒绝时间
  expiresAt   DateTime                      // 超时自动过期（默认 30 分钟）

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId, status])
  @@index([expiresAt])
  @@map("approval_requests")
}

// 技能注册表（兼容 Claude Code / OpenClaw Hub SKILL.md 标准）
model Skill {
  id            String   @id @default(uuid())
  slug          String   @unique // URL 友好标识，如 "fix-bug"
  name          String   // 显示名称
  description   String?  @db.Text
  category      String?  // 'pm' | 'cicd' | 'vc' | 'communication' | 'data_science'
  source        String   @default("internal") // 'openclaw-hub' | 'claude-code' | 'git' | 'local' | 'internal'
  sourceUrl     String?  // 原始来源链接
  version       String?  // 语义化版本
  author        String?
  license       String?
  compatibility String?  // 依赖声明
  manifest      Json?    // SKILL.md frontmatter 原始 JSON
  content       String?  @db.Text // SKILL.md body 内容
  isFeatured    Boolean  @default(false)
  isPublic      Boolean  @default(true)
  icon          String?  // lucide icon 名称
  tags          String[] // 标签数组
  installations SkillInstallation[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([source])
  @@index([isFeatured])
  @@map("skills")
}

// 技能安装记录（工作空间/用户级别）
model SkillInstallation {
  id          String   @id @default(uuid())
  skillId     String
  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userId      String?  // 安装用户（可选，为空表示工作空间级）
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String   @default("active") // 'active' | 'disabled' | 'pending'
  config      Json?    // 用户自定义配置
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([skillId, userId])
  @@index([userId])
  @@map("skill_installations")
}

// MCP Server 注册表
model MCPServer {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  category    String?  // 'pm' | 'cicd' | 'vc' | 'communication' | 'data_science'
  transport   String   @default("stdio") // 'stdio' | 'sse' | 'http'
  command     String?  // 启动命令（stdio 模式）
  args        Json?    // 启动参数（stdio 模式）
  env         Json?    // 环境变量（stdio 模式）
  url         String?  // 远程 URL（sse/http 模式）
  headers     Json?    // 自定义请求头（sse/http 模式）
  approved    Boolean  @default(false) // 是否已审批
  approvalConfig Json? // 审批配置 JSON {mode, allowedTools, disallowedTools, patterns}
  status      String   @default("unknown") // 'online' | 'degraded' | 'offline' | 'unknown'
  lastCheck   DateTime?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("mcp_servers")
}

// MCP 提示词模板
model MCPPrompt {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  serverId    String?  // 关联的 MCP Server ID（NULL 表示内置提示词）
  template    String   @db.Text
  variables   Json?    // 变量定义 [{name, description, required}]
  version     String   @default("1.0.0")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("mcp_prompts")
}

// MCP 资源缓存
model MCPResourceCache {
  id          String   @id @default(uuid())
  uri         String   @unique
  serverId    String?  // 来源 MCP Server ID
  content     String   @db.Text
  mimeType    String?  // MIME 类型
  expiresAt   DateTime // 过期时间
  createdAt   DateTime @default(now())

  @@index([expiresAt])
  @@map("mcp_resource_cache")
}

// OAuth 授权码存储（支持多实例部署，5 分钟过期）
model AuthCode {
  id          String   @id @default(uuid())
  code        String   @unique // 授权码
  userId      String   // 用户 UUID
  workId      String   // 工号
  consumed    Boolean  @default(false) // 是否已被消费（一次性使用）
  expiresAt   DateTime // 过期时间（5 分钟）
  createdAt   DateTime @default(now())

  @@index([code])
  @@index([expiresAt])
  @@map("auth_codes")
}
