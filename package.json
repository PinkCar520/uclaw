{
  "name": "uclaw",
  "version": "1.0.0",
  "description": "UClaw - 银行内网人工智能工作流中枢",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "turbo run dev",
    "gateway": "pnpm --filter gateway start:dev",
    "web": "pnpm --filter web dev",
    "lucid": "pnpm --filter lucid dev",
    "daemon": "pnpm --filter @uclaw/cli start daemon",
    "all": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "2.9.16",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}